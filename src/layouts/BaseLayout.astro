---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
}

const {
  title = "the segmented nerd",
  description = "Field notes on lateral security, micro-segmentation, NDR, and the practice of defending east-west networks.",
  ogTitle = title,
} = Astro.props;

const fullTitle = title === "the segmented nerd" ? title : `${title} — the segmented nerd`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!-- Set theme before first paint to prevent a flash. -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          if (stored === "dark" || stored === "light") {
            document.documentElement.setAttribute("data-theme", stored);
          }
          // If no stored preference, leave data-theme unset and let
          // the @media (prefers-color-scheme: dark) rule take over.
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
