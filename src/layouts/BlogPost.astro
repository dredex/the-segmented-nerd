---
import BaseLayout from "./BaseLayout.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props;
const { title, description, pubDate, author, tags } = entry.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year:  "numeric",
  month: "long",
  day:   "numeric",
});
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="post-header">
      <div class="container">
        <p class="eyebrow">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span class="dot">·</span>
          <span>{author}</span>
        </p>
        <h1 class="title">{title}</h1>
        <hr class="rule" />
        <p class="deck">{description}</p>
      </div>
    </header>

    <div class="container post-body">
      <slot />
    </div>

    {tags?.length > 0 && (
      <div class="container tag-row">
        <hr class="rule" />
        <p class="eyebrow tags">
          {tags.map((tag, i) => (
            <>
              {i > 0 && <span class="dot"> · </span>}
              <span>{tag}</span>
            </>
          ))}
        </p>
      </div>
    )}

    <footer class="post-footer container">
      <a href="/blog" class="eyebrow">← Back to writing</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding-block: 4rem 3rem;
    text-align: center;
  }
  .post-header .eyebrow {
    font-size: 0.68rem;
  }
  .dot {
    color: var(--text-subtle);
    margin: 0 0.5em;
  }
  .title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(2.2rem, 5vw + 0.6rem, 3.4rem);
    line-height: 1.14;
    letter-spacing: -0.015em;
    margin: 1rem 0 0;
    color: var(--text);
  }
  .deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.5;
  }

  .post-body {
    padding-block: 1rem 2rem;
    font-size: 1.05rem;
  }
  /* Hide duplicate H1 if the markdown leads with # Title */
  .post-body :global(h1):first-child {
    display: none;
  }
  /* Hide duplicate italic deck paragraph if the markdown leads with *...* */
  .post-body :global(> p:first-of-type:has(> em:only-child)) {
    display: none;
  }
  /* Section headings inside the post — serif, smaller than title, airy. */
  .post-body :global(h2) {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.6rem;
    text-align: center;
    margin-block: 2.8em 0.8em;
    letter-spacing: -0.005em;
  }
  .post-body :global(h3) {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--text-muted);
    text-align: center;
    margin-block: 2.4em 0.9em;
  }
  /* Drop cap on first paragraph — an editorial touch. */
  .post-body :global(> p:first-of-type:not(:has(em:only-child))::first-letter),
  .post-body :global(> p:nth-of-type(1)::first-letter) {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 3.4em;
    float: left;
    line-height: 0.85;
    padding: 0.1em 0.12em 0 0;
    color: var(--accent);
  }

  .tag-row {
    padding-block: 1rem 0;
    text-align: center;
  }
  .tags {
    font-size: 0.65rem;
    color: var(--text-subtle);
  }

  .post-footer {
    margin-top: 3rem;
    padding-block: 2rem 0;
    text-align: center;
  }
  .post-footer a {
    color: var(--text-muted);
    border-bottom: 0;
    font-size: 0.68rem;
  }
  .post-footer a:hover { color: var(--accent); }

  /* Figures — soft framing, slightly pushed out from the column */
  .post-body :global(figure) {
    margin: 2.6rem -1.5rem;
    padding: 0;
  }
  .post-body :global(figure img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 3px;
    border: 1px solid var(--border-soft);
    background: var(--bg-elev);
  }
  .post-body :global(figcaption) {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    text-align: center;
    margin-top: 0.8rem;
    text-transform: uppercase;
    line-height: 1.5;
  }
  @media (max-width: 720px) {
    .post-body :global(figure) { margin-inline: 0; }
    .post-header { padding-block: 2.5rem 2rem; }
  }
</style>
