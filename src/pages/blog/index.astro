---
const posts = [
  {
    slug: "day2-security-gap",
    title: "The Day 2 Security Gap in VCF 5.x",
    excerpt: "Most customers have DFW rules running. What they're missing is the path from basic firewalling into vDefend SSP and ATP — here's how to get there.",
    date: "2026-04-20",
    tags: ["vDefend", "SSP", "ATP"],
    readTime: "8 min",
    featured: true
  },
  {
    slug: "micro-segmentation-ignition-lock",
    title: "Micro-segmentation: The Ignition Lock",
    excerpt: "If you aren't segmenting the management plane, your zero-trust story has a hole in it the size of vCenter. Here's how to close it.",
    date: "2026-04-12",
    tags: ["NSX", "Zero Trust"],
    readTime: "6 min",
    featured: false
  },
  {
    slug: "avi-vcf-the-missing-tier",
    title: "AVI in VCF: The Load Balancing Tier You Already Own",
    excerpt: "Your VCF license includes AVI. Most customers are still running a hardware appliance next to it. Here's what AVI actually does and how to start using it.",
    date: "2026-04-21",
    tags: ["AVI", "VCF", "App Delivery"],
    readTime: "7 min",
    featured: false
  }
];
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Field Notes // The Segmented Nerd</title>
  <meta name="description" content="Technical field notes on VCF, vDefend SSP, NSX micro-segmentation, and enterprise security architecture." />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #007aff;
      --bg: #080808;
      --surface: #0f0f0f;
      --surface-2: #141414;
      --border: rgba(255,255,255,0.06);
      --border-hover: rgba(0,122,255,0.4);
      --text: rgba(255,255,255,0.5);
      --text-bright: rgba(255,255,255,0.92);
      --text-dim: rgba(255,255,255,0.2);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(8,8,8,0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 0 44px;
      height: 58px;
      display: flex;
      align-items: center;
      gap: 0;
    }

    .nav-home {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      color: var(--text-dim);
      text-decoration: none;
      letter-spacing: 2px;
      transition: color 0.2s;
    }
    .nav-home:hover { color: var(--blue); }

    .nav-sep {
      font-family: 'JetBrains Mono', monospace;
      color: rgba(255,255,255,0.1);
      margin: 0 12px;
      font-size: 0.6rem;
    }

    .nav-current {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      color: var(--text-dim);
      letter-spacing: 2px;
    }

    .nav-right {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .post-count-badge {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.5rem;
      color: var(--blue);
      border: 1px solid rgba(0,122,255,0.25);
      background: rgba(0,122,255,0.06);
      padding: 3px 9px;
      letter-spacing: 2px;
    }

    /* ── PAGE HERO ── */
    .page-hero {
      padding: 72px 44px 56px;
      max-width: 1080px;
      margin: 0 auto;
      border-bottom: 1px solid var(--border);
    }

    .page-hero-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      letter-spacing: 4px;
      color: var(--blue);
      text-transform: uppercase;
      margin-bottom: 16px;
      opacity: 0.8;
    }

    .page-hero-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 700;
      color: var(--text-bright);
      letter-spacing: 2px;
      line-height: 1.15;
      margin-bottom: 16px;
    }

    .page-hero-sub {
      font-size: 0.95rem;
      font-weight: 300;
      color: var(--text-dim);
      line-height: 1.7;
      max-width: 520px;
    }

    /* ── CONTENT ── */
    .content {
      max-width: 1080px;
      margin: 0 auto;
      padding: 56px 44px 100px;
    }

    /* ── FEATURED POST ── */
    .featured-post {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border: 1px solid var(--border);
      background: var(--surface);
      margin-bottom: 24px;
      text-decoration: none;
      position: relative;
      overflow: hidden;
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
      animation: fadeIn 0.5s ease forwards;
    }

    .featured-post::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(to right, var(--blue), transparent);
      opacity: 0.6;
      transition: opacity 0.3s ease;
    }

    .featured-post:hover {
      border-color: rgba(0,122,255,0.3);
      box-shadow: 0 0 0 1px rgba(0,122,255,0.1), 0 24px 60px rgba(0,0,0,0.4);
    }

    .featured-post:hover::before { opacity: 1; }

    .featured-post-body {
      padding: 40px 44px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .featured-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.52rem;
      letter-spacing: 3px;
      color: var(--blue);
      text-transform: uppercase;
      margin-bottom: 18px;
    }

    .featured-title {
      font-family: 'Inter', sans-serif;
      font-size: 1.45rem;
      font-weight: 600;
      color: var(--text-bright);
      line-height: 1.3;
      margin-bottom: 16px;
      letter-spacing: -0.3px;
    }

    .featured-excerpt {
      font-size: 0.88rem;
      font-weight: 300;
      color: var(--text);
      line-height: 1.8;
      margin-bottom: 32px;
      flex-grow: 1;
    }

    .featured-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .featured-meta {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .meta-date {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      color: var(--text-dim);
      letter-spacing: 1px;
    }

    .meta-read {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      color: var(--text-dim);
      letter-spacing: 1px;
    }

    .read-btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 2px;
      color: var(--blue);
      display: flex;
      align-items: center;
      gap: 8px;
      transition: gap 0.25s ease;
    }

    .featured-post:hover .read-btn { gap: 12px; }

    .featured-tags {
      padding: 40px 44px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      background: linear-gradient(135deg, rgba(0,122,255,0.04), transparent);
      border-left: 1px solid var(--border);
      gap: 10px;
    }

    .tags-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.5rem;
      color: var(--text-dim);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    /* ── POST LIST ── */
    .section-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
    }

    .section-title {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      color: var(--text-dim);
      letter-spacing: 3px;
      text-transform: uppercase;
    }

    .section-line {
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .post-list {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .post-card {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 32px;
      padding: 28px 32px;
      background: var(--surface);
      border: 1px solid var(--border);
      text-decoration: none;
      transition:
        border-color 0.25s ease,
        background 0.25s ease,
        transform 0.25s ease,
        box-shadow 0.25s ease;
      animation: fadeIn 0.5s ease forwards;
    }

    .post-card:hover {
      border-color: rgba(0,122,255,0.3);
      background: var(--surface-2);
      transform: translateX(4px);
      box-shadow: -4px 0 0 rgba(0,122,255,0.4), 0 8px 30px rgba(0,0,0,0.3);
    }

    .post-card-left { min-width: 0; }

    .post-card-tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .post-card-title {
      font-family: 'Inter', sans-serif;
      font-size: 1.05rem;
      font-weight: 500;
      color: var(--text-bright);
      line-height: 1.4;
      margin-bottom: 8px;
      letter-spacing: -0.2px;
      transition: color 0.2s ease;
    }

    .post-card:hover .post-card-title { color: #fff; }

    .post-card-excerpt {
      font-size: 0.82rem;
      font-weight: 300;
      color: var(--text);
      line-height: 1.7;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .post-card-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
      flex-shrink: 0;
    }

    .post-card-date {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.58rem;
      color: var(--text-dim);
      letter-spacing: 1px;
      white-space: nowrap;
    }

    .post-card-read {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      color: var(--text-dim);
      letter-spacing: 1px;
    }

    /* ── TAGS ── */
    .tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.52rem;
      color: rgba(0,122,255,0.55);
      border: 1px solid rgba(0,122,255,0.18);
      padding: 3px 9px;
      letter-spacing: 1px;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }

    a:hover .tag {
      color: rgba(0,122,255,0.8);
      border-color: rgba(0,122,255,0.35);
      background: rgba(0,122,255,0.06);
    }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 24px 44px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      color: var(--text-dim);
      letter-spacing: 2px;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
      nav, .page-hero, .content, footer { padding-left: 20px; padding-right: 20px; }
      .featured-post { grid-template-columns: 1fr; }
      .featured-tags { display: none; }
      .post-card { grid-template-columns: 1fr; gap: 12px; }
      .post-card-right { flex-direction: row; align-items: center; }
      .post-card-excerpt { white-space: normal; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="nav-home">// ROOT</a>
    <span class="nav-sep">/</span>
    <a href="/professional" class="nav-home">PROFESSIONAL</a>
    <span class="nav-sep">/</span>
    <span class="nav-current">FIELD NOTES</span>
    <div class="nav-right">
      <span class="post-count-badge">{posts.length} POSTS</span>
    </div>
  </nav>

  <div class="page-hero">
    <p class="page-hero-label">// Field Notes</p>
    <h1 class="page-hero-title">Enterprise Security<br/>from the Field</h1>
    <p class="page-hero-sub">
      Technical writing on VCF, vDefend SSP, AVI, and making the full
      stack work in real environments.
    </p>
  </div>

  <div class="content">

    {/* Featured post */}
    {posts.filter(p => p.featured).map(post => (
      <a href={`/blog/${post.slug}`} class="featured-post">
        <div class="featured-post-body">
          <div>
            <p class="featured-label">// Latest Post</p>
            <h2 class="featured-title">{post.title}</h2>
            <p class="featured-excerpt">{post.excerpt}</p>
          </div>
          <div class="featured-footer">
            <div class="featured-meta">
              <span class="meta-date">{post.date}</span>
              <span class="meta-read">{post.readTime} read</span>
            </div>
            <span class="read-btn">READ POST <span>→</span></span>
          </div>
        </div>
        <div class="featured-tags">
          <span class="tags-label">Topics</span>
          {post.tags.map(tag => <span class="tag">#{tag}</span>)}
        </div>
      </a>
    ))}

    {/* All other posts */}
    {posts.filter(p => !p.featured).length > 0 && (
      <div style="margin-top: 40px;">
        <div class="section-header">
          <span class="section-title">More Posts</span>
          <div class="section-line"></div>
        </div>
        <div class="post-list">
          {posts.filter(p => !p.featured).map(post => (
            <a href={`/blog/${post.slug}`} class="post-card">
              <div class="post-card-left">
                <div class="post-card-tags">
                  {post.tags.map(tag => <span class="tag">#{tag}</span>)}
                </div>
                <h2 class="post-card-title">{post.title}</h2>
                <p class="post-card-excerpt">{post.excerpt}</p>
              </div>
              <div class="post-card-right">
                <span class="post-card-date">{post.date}</span>
                <span class="post-card-read">{post.readTime}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>

  <footer>
    <span class="footer-label">// THE SEGMENTED NERD</span>
    <span class="footer-label">thesegmentednerd.com</span>
  </footer>

</body>
</html>
