---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) => d.toLocaleDateString("en-US", {
  year: "numeric", month: "short", day: "numeric",
});
---

<BaseLayout title="blog — the segmented nerd" description="Every post on the segmented nerd.">
  <section class="container">
    <header class="page-header">
      <h1>blog</h1>
      <p class="muted">Field notes on lateral security, east-west defense, and the products that shape it. New posts on the 1st and 15th.</p>
    </header>

    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}/`} class="post-row">
            <time class="mono small" datetime={post.data.pubDate.toISOString()}>
              {fmt(post.data.pubDate)}
            </time>
            <div class="post-row-body">
              <h2>{post.data.title}</h2>
              <p class="muted">{post.data.description}</p>
              {post.data.tags?.length > 0 && (
                <ul class="tags">
                  {post.data.tags.map((tag) => (
                    <li class="mono small">#{tag}</li>
                  ))}
                </ul>
              )}
            </div>
          </a>
        </li>
      ))}
      {posts.length === 0 && (
        <li class="empty muted">Nothing here yet. The first post is landing soon.</li>
      )}
    </ul>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--border-soft);
  }
  .page-header h1 {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.8rem;
    margin-block: 0 0.3em;
  }
  .page-header p { margin: 0; }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list > li + li {
    border-top: 1px solid var(--border-soft);
  }
  .post-row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1.5rem;
    padding: 1.4rem 0;
    text-decoration: none;
    color: inherit;
    border-bottom: 0;
    transition: background-color 0.15s ease;
    border-radius: 4px;
  }
  .post-row:hover {
    background: var(--bg-elev);
    padding-inline: 0.6rem;
    margin-inline: -0.6rem;
  }
  .post-row time {
    color: var(--text-muted);
    padding-top: 0.35em;
    white-space: nowrap;
  }
  .post-row h2 {
    font-size: 1.2rem;
    margin-block: 0 0.35em;
    font-weight: 600;
  }
  .post-row:hover h2 { color: var(--accent); }
  .post-row p { margin: 0; }

  .tags {
    list-style: none;
    padding: 0;
    margin-top: 0.7rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .tags li { color: var(--text-subtle); }

  .empty { padding: 2rem 0; text-align: center; }

  @media (max-width: 600px) {
    .post-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .post-row time { padding-top: 0; }
  }
</style>
