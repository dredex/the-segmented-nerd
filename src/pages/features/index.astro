---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type FeatureEntry = CollectionEntry<"features">;

const all = (await getCollection("features", ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const hostOf = (url?: string) => {
  if (!url) return "";
  try {
    return new URL(url).host.replace(/^www\./, "");
  } catch {
    return "";
  }
};
---

<BaseLayout
  title="Features"
  description="New features shipping in vDefend, Avi, and the Security Services Platform — short callouts, often with a screenshot."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Shipping now</p>
      <h1 class="page-title">Features</h1>
      <hr class="rule" />
    </div>
  </section>

  {all.length > 0 ? (
    <section class="container features-wrap" aria-label="Feature callouts">
      <div class="features-grid">
        {all.map((item) => (
          <article class="feature-card">
            {item.data.screenshot && (
              <a
                class="shot-link"
                href={item.data.source ?? item.data.screenshot}
                target={item.data.source ? "_blank" : undefined}
                rel={item.data.source ? "noopener" : undefined}
              >
                <img
                  class="shot"
                  src={item.data.screenshot}
                  alt={item.data.screenshotAlt ?? item.data.title}
                  loading="lazy"
                />
              </a>
            )}
            <div class="feature-body">
              <p class="eyebrow feature-meta">
                {item.data.product && <span class="product">{item.data.product}</span>}
                {item.data.product && item.data.version && <span class="meta-dot"> · </span>}
                {item.data.version && <span class="version">v{item.data.version}</span>}
              </p>
              <h2 class="feature-title">
                {item.data.source ? (
                  <a href={item.data.source} target="_blank" rel="noopener">
                    {item.data.title}
                  </a>
                ) : (
                  item.data.title
                )}
              </h2>
              <p class="feature-summary">{item.data.summary}</p>
              <p class="feature-foot eyebrow muted">
                <time datetime={item.data.pubDate.toISOString()}>
                  {fmt(item.data.pubDate)}
                </time>
                {item.data.source && (
                  <>
                    <span class="meta-dot"> · </span>
                    <a class="src-link" href={item.data.source} target="_blank" rel="noopener">
                      {item.data.sourceLabel ?? hostOf(item.data.source)} →
                    </a>
                  </>
                )}
              </p>
            </div>
          </article>
        ))}
      </div>
    </section>
  ) : (
    <section class="container empty-wrap">
      <p class="muted empty">No feature callouts yet. Check back soon.</p>
    </section>
  )}
</BaseLayout>

<style>
  .page-hero {
    padding-block: 4rem 3rem;
    text-align: center;
  }
  .page-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    letter-spacing: -0.01em;
    margin: 0.8rem 0 0;
  }
  .page-deck {
    max-width: 560px;
    margin-inline: auto;
    font-size: 1rem;
  }

  .features-wrap {
    padding-block: 1rem 4rem;
  }
  .features-grid {
    display: grid;
    gap: 1.6rem;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    max-width: 1040px;
    margin-inline: auto;
  }

  .feature-card {
    background: var(--bg-elev);
    border: 1px solid var(--border-soft);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .shot-link {
    display: block;
    border-bottom: 1px solid var(--border-soft);
    border-radius: 0;
    background: var(--bg);
  }
  .shot {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 280px;
  }

  .feature-body {
    padding: 1.4rem 1.4rem 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .feature-meta {
    font-size: 0.62rem;
    letter-spacing: 0.24em;
    margin-bottom: 0.45rem;
  }
  .product {
    color: var(--accent);
    font-weight: 700;
  }
  .version {
    color: var(--text-muted);
  }
  .meta-dot {
    color: var(--text-subtle);
    margin-inline: 0.15em;
  }
  .feature-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.3rem;
    line-height: 1.3;
    letter-spacing: -0.005em;
    margin: 0 0 0.55rem;
    color: var(--text);
  }
  .feature-title a {
    color: inherit;
    border-bottom: 0;
    transition: color 0.15s ease;
  }
  .feature-title a:hover { color: var(--accent); }
  .feature-summary {
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0;
    flex: 1;
  }
  .feature-foot {
    margin-top: 1.2rem;
    font-size: 0.6rem;
    color: var(--text-subtle);
  }
  .src-link {
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 0;
  }
  .src-link:hover { color: var(--accent); }

  .empty-wrap { padding-block: 3rem 5rem; text-align: center; }
  .empty { font-size: 1rem; }
</style>
