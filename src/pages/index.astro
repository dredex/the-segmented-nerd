---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const all = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [lead, ...rest] = all;
const next = rest.slice(0, 4);

const fmt = (d: Date) => d.toLocaleDateString("en-US", {
  year: "numeric", month: "long", day: "numeric",
});
---

<BaseLayout>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Issue · Biweekly · Est. 2026</p>
      <h1 class="hero-title">
        Defending what moves <em>inside</em> the perimeter.
      </h1>
      <hr class="rule" />
      <p class="hero-deck">
        Field notes on lateral security, micro-segmentation, east-west detection, and the
        products shaping how we defend internal networks. Written for the security and network
        engineers actually configuring the distributed firewalls.
      </p>
      <p class="eyebrow cadence">New writing on the 1st &amp; 15th of every month</p>
    </div>
  </section>

  {lead && (
    <section class="band">
      <div class="container">
        <p class="eyebrow section-label">The latest</p>
        <article class="lead">
          <a href={`/blog/${lead.id}/`} class="lead-link">
            <time class="eyebrow" datetime={lead.data.pubDate.toISOString()}>
              {fmt(lead.data.pubDate)}
            </time>
            <h2 class="lead-title">{lead.data.title}</h2>
            <p class="lead-deck">{lead.data.description}</p>
            <span class="lead-more eyebrow">Read the essay →</span>
          </a>
        </article>
      </div>
    </section>
  )}

  {next.length > 0 && (
    <section class="more container">
      <p class="eyebrow section-label centered">Also in the archive</p>
      <hr class="rule" />
      <ul class="more-list">
        {next.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <time class="eyebrow" datetime={post.data.pubDate.toISOString()}>
                {fmt(post.data.pubDate)}
              </time>
              <h3>{post.data.title}</h3>
              <p class="muted">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
      <p class="browse-all"><a href="/blog" class="eyebrow">Browse every issue →</a></p>
    </section>
  )}

  {!lead && (
    <section class="container empty">
      <hr class="rule" />
      <p class="muted">The inaugural issue lands soon.</p>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding-block: 4.5rem 4rem;
    text-align: center;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(2.2rem, 4.5vw + 0.6rem, 3.6rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-block: 1rem 0;
  }
  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }
  .hero-deck {
    font-size: 1.08rem;
    color: var(--text-muted);
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.65;
  }
  .cadence {
    margin-top: 1.8rem;
    font-size: 0.68rem;
  }

  .section-label {
    text-align: center;
    margin-bottom: 1.2rem;
  }
  .section-label.centered { text-align: center; }

  .lead { text-align: center; }
  .lead-link {
    display: block;
    text-decoration: none;
    border-bottom: 0;
    color: inherit;
    max-width: 640px;
    margin-inline: auto;
  }
  .lead-link time {
    display: block;
    margin-bottom: 1rem;
  }
  .lead-title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.8rem, 3vw + 0.6rem, 2.6rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 0.6em;
    color: var(--text);
    transition: color 0.2s ease;
  }
  .lead-link:hover .lead-title { color: var(--accent); }
  .lead-deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--text-muted);
    margin: 0 0 1.4rem;
    line-height: 1.5;
  }
  .lead-more {
    font-size: 0.7rem;
    color: var(--accent);
  }

  .more {
    padding-block: 4rem 2rem;
  }
  .more-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 3rem;
  }
  .more-list a {
    display: block;
    text-decoration: none;
    border-bottom: 0;
    color: inherit;
  }
  .more-list time {
    display: block;
    margin-bottom: 0.7rem;
    font-size: 0.65rem;
  }
  .more-list h3 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.3rem;
    line-height: 1.25;
    margin: 0 0 0.5rem;
    color: var(--text);
    transition: color 0.15s ease;
  }
  .more-list a:hover h3 { color: var(--accent); }
  .more-list p { margin: 0; font-size: 0.95rem; }

  .browse-all {
    text-align: center;
    margin-top: 3rem;
  }
  .browse-all a {
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
  }

  .empty { padding-block: 4rem; text-align: center; }

  @media (max-width: 640px) {
    .more-list { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero { padding-block: 3rem 3rem; }
  }
</style>
