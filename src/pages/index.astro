---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const latest = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const fmt = (d: Date) => d.toLocaleDateString("en-US", {
  year: "numeric", month: "short", day: "numeric",
});
---

<BaseLayout>
  <section class="container intro">
    <h1>
      <span class="mono accent">//</span> the segmented nerd
    </h1>
    <p>
      Field notes on lateral security, micro-segmentation, east-west
      detection, and the products shaping how we defend inside the perimeter.
      Written for security and network engineers — the people actually
      running the distributed firewalls.
    </p>
    <p class="muted small mono">
      new posts on the 1st and 15th · <a href="/blog">browse the archive →</a>
    </p>
  </section>

  <section class="container latest">
    <h2>Recent</h2>
    <ul>
      {latest.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>
            <time class="mono small" datetime={post.data.pubDate.toISOString()}>
              {fmt(post.data.pubDate)}
            </time>
            <span class="title">{post.data.title}</span>
          </a>
        </li>
      ))}
      {latest.length === 0 && (
        <li class="empty muted">Nothing published yet. The first post is landing soon.</li>
      )}
    </ul>
  </section>
</BaseLayout>

<style>
  .intro {
    padding: 1.5rem 0 2.5rem;
  }
  .intro h1 {
    font-size: clamp(2rem, 5vw + 0.5rem, 2.8rem);
    font-weight: 600;
    margin-block: 0 0.6em;
    letter-spacing: -0.02em;
  }
  .intro h1 .accent { color: var(--accent); margin-right: 0.3em; }
  .intro p { font-size: 1.05rem; }

  .latest {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-soft);
  }
  .latest h2 {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-muted);
    text-transform: lowercase;
    letter-spacing: 0.02em;
    margin-block: 0 1rem;
  }
  .latest ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .latest li + li {
    border-top: 1px solid var(--border-soft);
  }
  .latest a {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1.2rem;
    padding: 0.85rem 0;
    align-items: baseline;
    text-decoration: none;
    color: inherit;
    border-bottom: 0;
  }
  .latest a:hover .title { color: var(--accent); }
  .latest time { color: var(--text-muted); white-space: nowrap; }
  .title { color: var(--text); }
  .empty { padding: 1rem 0; list-style: none; }

  @media (max-width: 600px) {
    .latest a {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>
