---
const siteTitle = "THE SEGMENTED NERD";
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { --green: #00ff41; --blue: #007aff; --bg: #0a0a0a; --border: #222; }
        body { background: var(--bg); color: #fff; font-family: 'JetBrains Mono', monospace; margin: 0; overflow: hidden; }
        .split-container { display: flex; height: 100vh; width: 100vw; }
        .side { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; text-decoration: none; transition: 0.5s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid var(--border); position: relative; }
        
        /* Professional Side */
        .pro { background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1558494949-ef010cbdcc51?q=80&w=2000'); background-size: cover; }
        .pro:hover { flex: 1.5; background: rgba(0, 122, 255, 0.1); border-color: var(--blue); }
        .pro h2 { color: var(--blue); }

        /* Personal Side */
        .personal { background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1581092160562-40aa08e78837?q=80&w=2000'); background-size: cover; }
        .personal:hover { flex: 1.5; background: rgba(0, 255, 65, 0.1); border-color: var(--green); }
        .personal h2 { color: var(--green); }

        h2 { font-size: 1.5rem; letter-spacing: 5px; margin: 0; z-index: 2; }
        p { font-size: 0.8rem; color: #888; margin-top: 10px; z-index: 2; }
        .label { position: absolute; top: 20px; font-size: 0.6rem; color: #444; letter-spacing: 2px; }
    </style>
</head>
<body>
    <div class="split-container">
        <a href="/professional" class="side pro">
            <span class="label">SEGMENT_01</span>
            <h2>[ PROFESSIONAL ]</h2>
            <p>VCF // vDefend // Cloud Architecture</p>
        </a>
        <a href="/personal" class="side personal">
            <span class="label">SEGMENT_02</span>
            <h2>[ PERSONAL ]</h2>
            <p>3D Printing // Woodworking // Fleet</p>
        </a>
    </div>
</body>
</html>
