---
const title = "ENTERPRISE ARCHITECTURE";
const subtitle = "VCF & VDEFEND FIELD NOTES";
const status = "TAM // VERIFIED STAFF";

const posts = [
  {
    slug: "day2-security-gap",
    title: "The Day 2 Security Gap in VCF 5.x",
    excerpt: "Most customers have DFW rules running. What they're missing is the path from basic firewalling into vDefend SSP and ATP — here's how to get there.",
    date: "2026-04-20",
    tags: ["vDefend", "Security", "VCF"],
    readTime: "8 min",
    featured: true
  },
  {
    slug: "micro-segmentation-ignition-lock",
    title: "Micro-segmentation: The Ignition Lock",
    excerpt: "Treating your network like a zero-trust enclave. If you aren't segmenting the management plane, you aren't secure.",
    date: "2026-04-12",
    tags: ["NSX", "Zero Trust", "Micro-segmentation"],
    readTime: "6 min",
    featured: false
  }
];
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} // The Segmented Nerd</title>
  <meta name="description" content="Field notes on VCF, vDefend ATP, NSX micro-segmentation, and enterprise cloud architecture." />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --blue: #007aff;
      --bg: #0d0d0d;
      --card: #111;
      --card-hover: #141414;
      --border: #1a1a1a;
      --border-bright: #252525;
      --text: #888;
      --text-bright: #fff;
      --text-dim: #444;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'JetBrains Mono', monospace;
      margin: 0;
      padding: 0;
      line-height: 1.7;
      min-height: 100vh;
    }

    /* Scanline */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        to bottom, transparent 0px, transparent 3px,
        rgba(0,0,0,0.03) 3px, rgba(0,0,0,0.03) 4px
      );
      pointer-events: none;
      z-index: 1000;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 500;
      background: rgba(13, 13, 13, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      padding: 14px 40px;
      display: flex;
      align-items: center;
      gap: 0;
    }

    .nav-home {
      font-size: 0.65rem;
      color: var(--text-dim);
      text-decoration: none;
      letter-spacing: 2px;
      transition: color 0.2s;
    }
    .nav-home:hover { color: var(--blue); }

    .nav-sep { color: #222; margin: 0 10px; font-size: 0.65rem; }

    .nav-current {
      font-size: 0.65rem;
      color: var(--text);
      letter-spacing: 2px;
    }

    .nav-links {
      margin-left: auto;
      display: flex;
      gap: 24px;
    }

    .nav-links a {
      font-size: 0.6rem;
      color: var(--text-dim);
      text-decoration: none;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--blue); }
    .nav-links a.active { color: var(--blue); }

    /* ── LAYOUT ── */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 50px 40px;
    }

    /* ── HEADER ── */
    .page-header {
      border-bottom: 1px solid var(--border);
      padding-bottom: 30px;
      margin-bottom: 50px;
    }

    .header-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
    }

    .page-title {
      color: var(--text-bright);
      font-size: 1.05rem;
      margin: 0 0 6px 0;
      letter-spacing: 3px;
      font-weight: 700;
    }

    .page-subtitle {
      color: var(--blue);
      font-size: 0.65rem;
      letter-spacing: 3px;
      margin: 0;
    }

    .status-badge {
      font-size: 0.55rem;
      color: var(--blue);
      border: 1px solid rgba(0, 122, 255, 0.3);
      padding: 5px 12px;
      letter-spacing: 2px;
      background: rgba(0, 122, 255, 0.05);
    }

    /* ── HERO ── */
    .hero {
      background: rgba(0, 122, 255, 0.04);
      border: 1px solid rgba(0, 122, 255, 0.15);
      border-left: 3px solid var(--blue);
      padding: 28px 30px;
      margin-bottom: 50px;
    }

    .hero-label {
      font-size: 0.55rem;
      color: var(--blue);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin: 0 0 12px 0;
    }

    .hero p {
      margin: 0;
      font-size: 0.85rem;
      line-height: 1.8;
      color: #999;
    }

    /* ── GRID ── */
    .main-grid {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 40px;
      align-items: start;
    }

    /* ── POSTS ── */
    .section-label {
      font-size: 0.6rem;
      color: var(--text-dim);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin: 0 0 20px 0;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }

    .post-card {
      background: var(--card);
      border: 1px solid var(--border);
      padding: 24px;
      margin-bottom: 16px;
      text-decoration: none;
      display: block;
      transition: border-color 0.25s ease,
                  background 0.25s ease,
                  transform 0.25s ease;
    }

    .post-card:hover {
      border-color: var(--blue);
      background: var(--card-hover);
      transform: translateX(4px);
    }

    .post-card.featured {
      border-left: 3px solid var(--blue);
    }

    .post-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 10px;
    }

    .post-title {
      color: var(--text-bright);
      font-size: 0.9rem;
      font-weight: 500;
      margin: 0;
      line-height: 1.4;
    }

    .featured-chip {
      font-size: 0.5rem;
      color: var(--blue);
      border: 1px solid rgba(0,122,255,0.3);
      padding: 2px 7px;
      letter-spacing: 2px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .post-excerpt {
      font-size: 0.8rem;
      color: var(--text);
      margin: 0 0 14px 0;
      line-height: 1.7;
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 0.62rem;
      color: var(--text-dim);
    }

    .post-tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-left: auto;
    }

    .tag {
      font-size: 0.55rem;
      color: #333;
      border: 1px solid #1e1e1e;
      padding: 2px 7px;
      letter-spacing: 1px;
      transition: color 0.2s, border-color 0.2s;
    }

    .post-card:hover .tag {
      color: rgba(0, 122, 255, 0.5);
      border-color: rgba(0, 122, 255, 0.2);
    }

    .view-all {
      display: inline-block;
      margin-top: 8px;
      font-size: 0.62rem;
      color: var(--text-dim);
      text-decoration: none;
      letter-spacing: 2px;
      transition: color 0.2s;
    }
    .view-all:hover { color: var(--blue); }

    /* ── SIDEBAR ── */
    .sidebar { display: flex; flex-direction: column; gap: 20px; }

    .sidebar-card {
      background: #0e0e0e;
      border: 1px solid var(--border);
      padding: 20px;
    }

    .sidebar-label {
      font-size: 0.58rem;
      color: var(--blue);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin: 0 0 14px 0;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }

    .skill-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 9px;
    }

    .skill-list li {
      font-size: 0.75rem;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .skill-list li::before {
      content: '>';
      color: var(--blue);
      font-weight: 700;
      flex-shrink: 0;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .stat {
      background: #0a0a0a;
      border: 1px solid var(--border);
      padding: 12px;
      text-align: center;
    }

    .stat-value {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--blue);
      display: block;
    }

    .stat-label {
      font-size: 0.5rem;
      color: var(--text-dim);
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .vmug-note {
      font-size: 0.72rem;
      color: var(--text-dim);
      margin: 0;
      font-style: italic;
    }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 20px 40px;
      font-size: 0.58rem;
      color: var(--text-dim);
      display: flex;
      justify-content: space-between;
      letter-spacing: 1px;
    }

    @media (max-width: 768px) {
      nav { padding: 14px 20px; }
      .container { padding: 30px 20px; }
      .main-grid { grid-template-columns: 1fr; }
      .header-top { flex-direction: column; gap: 12px; }
      footer { flex-direction: column; gap: 6px; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="nav-home">// ROOT</a>
    <span class="nav-sep">/</span>
    <span class="nav-current">PROFESSIONAL</span>
    <div class="nav-links">
      <a href="/professional" class="active">HUB</a>
      <a href="/blog">FIELD NOTES</a>
    </div>
  </nav>

  <div class="container">

    <header class="page-header">
      <div class="header-top">
        <div>
          <h1 class="page-title">[ {title} ]</h1>
          <p class="page-subtitle">{subtitle}</p>
        </div>
        <span class="status-badge">{status}</span>
      </div>
    </header>

    <div class="hero">
      <p class="hero-label">// CURRENT_FOCUS</p>
      <p>
        I specialize in the adoption of enterprise-grade software architectures,
        focusing on the intersection of virtualization, micro-segmentation, and
        application networking within the VMware Cloud Foundation (VCF) stack.
        These field notes document real-world patterns, failures, and fixes from
        production environments.
      </p>
    </div>

    <div class="main-grid">

      <main>
        <p class="section-label">// LATEST_FIELD_NOTES</p>

        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class={`post-card${post.featured ? ' featured' : ''}`}>
            <div class="post-card-header">
              <h2 class="post-title">{post.title}</h2>
              {post.featured && <span class="featured-chip">LATEST</span>}
            </div>
            <p class="post-excerpt">{post.excerpt}</p>
            <div class="post-meta">
              <span>{post.date}</span>
              <span>{post.readTime} read</span>
              <div class="post-tags">
                {post.tags.map(tag => <span class="tag">#{tag.toUpperCase()}</span>)}
              </div>
            </div>
          </a>
        ))}

        <a href="/blog" class="view-all">VIEW ALL FIELD NOTES →</a>
      </main>

      <aside class="sidebar">

        <div class="sidebar-card">
          <p class="sidebar-label">// CORE_COMPETENCIES</p>
          <ul class="skill-list">
            <li>VCF Stack Architecture</li>
            <li>vDefend SSP Onboarding</li>
            <li>vDefend ATP Enablement</li>
            <li>Distributed Firewall Design</li>
            <li>Kubernetes on vSphere</li>
            <li>Automation (Python / PowerShell)</li>
          </ul>
        </div>

        <div class="sidebar-card">
          <p class="sidebar-label">// BY THE NUMBERS</p>
          <div class="stat-grid">
            <div class="stat">
              <span class="stat-value">2</span>
              <span class="stat-label">Posts</span>
            </div>
            <div class="stat">
              <span class="stat-value">5+</span>
              <span class="stat-label">Yrs VCF</span>
            </div>
            <div class="stat">
              <span class="stat-value">∞</span>
              <span class="stat-label">Lab Hours</span>
            </div>
            <div class="stat">
              <span class="stat-value">0</span>
              <span class="stat-label">Downtime</span>
            </div>
          </div>
        </div>

        <div class="sidebar-card" style="opacity: 0.6;">
          <p class="sidebar-label">// UPCOMING_VMUGS</p>
          <p class="vmug-note">Session updates and deep-dives coming soon.</p>
        </div>

      </aside>
    </div>
  </div>

  <footer>
    <span>// THE SEGMENTED NERD</span>
    <span>thesegmentednerd.com</span>
  </footer>

</body>
</html>
